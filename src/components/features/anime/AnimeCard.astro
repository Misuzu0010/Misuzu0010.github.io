---
import Image from "@components/atoms/Image/Image.astro";
import type { MediaItem } from "../../../data/anime";

interface Props {
    item: MediaItem;
    statusInfo: {
        text: string;
        class: string;
        icon: string;
    };
    yearLabel: string;
    studioLabel: string;
}

const { item, statusInfo, yearLabel, studioLabel } = Astro.props;

// 【逻辑运算区】计算各种进度百分比
const animeProgress =
    item.type === "anime" && item.totalEpisodes > 0
        ? (item.progress / item.totalEpisodes) * 100
        : 0;

const gameTimeProgress =
    item.type === "galgame" && item.playTime > 0
        ? (item.currentTime / item.playTime) * 100
        : 0;

const gameRouteProgress =
    item.type === "galgame" && item.totalRoutes > 0
        ? (item.clearedRoutes / item.totalRoutes) * 100
        : 0;

const makerName = item.type === "anime" ? item.studio : item.developer;
---

<div
    class="group relative bg-[var(--card-bg)] border border-[var(--line-divider)] rounded-[var(--radius-large)] overflow-hidden hover:shadow-lg flex flex-col h-full"
    data-anime-status={item.status}
>
    <div class="relative anime-cover-container aspect-[2/3] overflow-hidden shrink-0">
        <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full h-full"
        >
            <Image
                src={item.cover}
                alt={item.title}
                class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-110"
                widths={[200, 400, 600]}
                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 25vw, 20vw"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-800 ml-1" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"></path>
                        </svg>
                    </div>
                </div>
            </div>
        </a>

        <div class={`absolute top-2 left-2 px-2 py-1 rounded-md text-xs font-medium ${statusInfo.class}`}>
            <span class="mr-1">{statusInfo.icon}</span>
            <span>{statusInfo.text}</span>
        </div>

        <div class="absolute top-2 right-2 bg-black/70 text-white px-2 py-1 rounded-md text-xs font-medium flex items-center gap-1">
            <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <span>{item.rating}</span>
        </div>

        {(item.status === "watching" || item.status === "completed") && (
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/50 to-transparent p-2 pt-6">
                
                {/* 番剧：单根进度条 */}
                {item.type === "anime" && (
                    <div class="mb-1">
                        <div class="flex justify-between text-white text-[10px] font-medium mb-1">
                            <span>EP. {item.progress}/{item.totalEpisodes}</span>
                            <span>{Math.round(animeProgress)}%</span>
                        </div>
                        <div class="w-full bg-white/20 rounded-full h-1.5">
                            <div class="bg-gradient-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300" style={`width: ${animeProgress}%`} />
                        </div>
                    </div>
                )}

                {/* Galgame：双根进度条 */}
                {item.type === "galgame" && (
                    <div class="flex flex-col gap-2">
                        {/* 时长进度条 */}
                        <div>
                            <div class="flex justify-between text-white text-[10px] font-medium mb-1">
                                <span>⏱️ {item.currentTime}h / {item.playTime}h</span>
                                <span>{Math.round(gameTimeProgress)}%</span>
                            </div>
                            <div class="w-full bg-white/20 rounded-full h-1.5">
                                <div class="bg-gradient-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300" style={`width: ${gameTimeProgress}%`} />
                            </div>
                        </div>
                        {/* 路线进度条 */}
                        <div class="mb-1">
                            <div class="flex justify-between text-white text-[10px] font-medium mb-1">
                                <span>🚩 {item.clearedRoutes} / {item.totalRoutes} 线</span>
                                <span>{Math.round(gameRouteProgress)}%</span>
                            </div>
                            <div class="w-full bg-white/20 rounded-full h-1.5">
                                <div class="bg-gradient-to-r from-pink-400 to-rose-400 h-1.5 rounded-full transition-all duration-300" style={`width: ${gameRouteProgress}%`} />
                            </div>
                        </div>
                    </div>
                )}
            </div>
        )}
    </div>

    <div class="p-3 flex flex-col grow">
        <h3 class="text-sm font-bold text-black/90 dark:text-white/90 mb-1 leading-tight line-clamp-1">
            {item.title}
        </h3>
        <p class="text-black/60 dark:text-white/60 text-xs mb-3 line-clamp-2" title={item.description}>
            {item.description}
        </p>

        <div class="space-y-1 text-xs mt-auto">
            <div class="flex justify-between items-center">
                <span class="text-black/50 dark:text-white/50 shrink-0">{yearLabel}</span>
                <span class="text-black/70 dark:text-white/70 truncate ml-2 text-right">{item.year}</span>
            </div>
            <div class="flex justify-between items-start">
                <span class="text-black/50 dark:text-white/50 shrink-0 mt-0.5">{studioLabel}</span>
                <span class="text-black/70 dark:text-white/70 text-right ml-2 line-clamp-2 break-words" title={makerName}>
                    {makerName}
                </span>
            </div>
            <div class="flex flex-wrap gap-1 pt-2 mt-1">
                {item.genre.map((g) => (
                    <span class="px-1.5 py-0.5 bg-[var(--btn-regular-bg)] text-black/70 dark:text-white/70 rounded text-xs">
                        {g}
                    </span>
                ))}
            </div>
        </div>
    </div>
</div>